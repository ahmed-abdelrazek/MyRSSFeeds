<Window
    x:Class="MyRSSFeeds.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MyRSSFeeds.WinUI.Views">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  The system title bar can't show an icon in WinUI 3, so the window
              draws its own: this row is registered via SetTitleBar and keeps
              the standard drag/caption-button behavior.  -->
        <Grid x:Name="AppTitleBar" Height="32">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="16,0,0,0">
                    <Image.Source>
                        <SvgImageSource RasterizePixelHeight="32" RasterizePixelWidth="32" UriSource="ms-appx:///Assets/logo.svg" />
                    </Image.Source>
                </Image>
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="My RSS Feeds" />
            </StackPanel>
        </Grid>

        <views:ShellPage Grid.Row="1" />
    </Grid>
</Window>
