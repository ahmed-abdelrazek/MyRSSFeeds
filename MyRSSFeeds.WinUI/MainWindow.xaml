<Window
    x:Class="MyRSSFeeds.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MyRSSFeeds.WinUI.Views">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  The system title bar can't show an icon in WinUI 3; the WinUI
              TitleBar control draws the icon and title declaratively and is
              registered as the window's title bar in code-behind.  -->
        <!--  The icon file must have a qualifier-free name: MRT parses tokens
              like targetsize-48/altform-unplated out of asset filenames, so
              ms-appx URIs that include them resolve to nothing.  -->
        <TitleBar
            x:Name="AppTitleBar"
            Title="My RSS Feeds"
            BackRequested="AppTitleBar_BackRequested"
            IsBackButtonVisible="True"
            IsBackButtonEnabled="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/TitleBarLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <views:ShellPage Grid.Row="1" />
    </Grid>
</Window>
